# ─────────────────────────────────────────
# DATAOPS CONTROL CENTER — Variables de Entorno
# Copia este archivo como .env y llena los valores reales
# NUNCA subas el .env real a Git
# ─────────────────────────────────────────
# PostgreSQL
POSTGRES_USER=dataops
POSTGRES_PASSWORD=dataops123
POSTGRES_DB=dataops_db

# JWT
JWT_SECRET=cambia_esto_por_una_clave_segura_muy_larga

# Grafana
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin123

# Email (para alertas)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_correo@gmail.com
SMTP_PASS=tu_app_password

# AWS S3 (para backups en nube — opcional)
AWS_ACCESS_KEY=
AWS_SECRET_KEY=
AWS_BUCKET=dataops-backups

# Azure Blob Storage (alternativa a AWS — opcional)
AZURE_CONNECTION_STRING=
